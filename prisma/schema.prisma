generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =================================================
// ENUMS
// =================================================
enum Status {
  SOLVED
  ATTEMPTED
  NEEDS_REVIEW
}

// =================================================
// 1. USER TABLE (Identity & Dashboard Stats)
// =================================================
model User {
  id            String         @id // Matches Clerk User ID
  email         String         @unique
  fullName      String?

  // totalSolved = COUNT(SolvedProblem WHERE userId = ?)
  // Increments ONLY on a genuinely new solve, never for alternates or re-submissions
  totalSolved   Int            @default(0)
  currentStreak Int            @default(0)
  maxStreak     Int            @default(0)

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  // Relationships
  submissions   Submission[]
  solvedProblems SolvedProblem[]
  comments      Comment[]
}

// =================================================
// 2. PROBLEM TABLE (Static Catalog)
// =================================================
model Problem {
  slug            String         @id // e.g., "33-search-in-rotated-sorted-array"
  title           String

  // Community average of all non-null Submission.difficultyRating values
  difficultyValue Float?
  difficultyLabel String?        // "Easy" | "Medium" | "Hard" (from platform API)

  platform        String         // "leetcode", "codeforces", "other"
  url             String?
  rating          Int?           // Codeforces rating

  // Relationships
  submissions     Submission[]
  solvedProblems  SolvedProblem[]

  @@index([platform])
}

// =================================================
// 3. SOLVED PROBLEM TABLE (Canonical Solve Registry)
//    One row per (userId, problemSlug) pair.
//    This is the source of truth for "did this user
//    ever solve this problem?"
// =================================================
model SolvedProblem {
  id              String       @id @default(uuid())

  // When the user FIRST solved this problem (immutable after creation)
  firstSolvedAt   DateTime     @default(now())

  // Set explicitly on every new submission/re-submission.
  // Powers archive sort order (DESC = most recently active at top).
  // NOT @updatedAt — we manage this field manually so historical dates
  // can be written during migration without Prisma overriding them.
  lastAttemptedAt DateTime     @default(now())

  // Shared problem-level metadata for this user.
  // These are updated (not duplicated) on re-submissions.
  notes           String?      @db.Text
  tags            String[]
  difficultyRating Float?

  // Foreign Keys
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  problemSlug     String
  problem         Problem      @relation(fields: [problemSlug], references: [slug], onDelete: Cascade)

  // All code submissions for this user+problem (main + alternates + re-submissions)
  submissions     Submission[]

  @@unique([userId, problemSlug])
  @@index([userId, lastAttemptedAt])  // Powers archive feed ordering
  @@index([problemSlug])
}

// =================================================
// 4. SUBMISSION TABLE (Code Artifact Store)
//    Every row is a specific piece of code the user
//    wrote. Not all submissions = solved problems.
// =================================================
model Submission {
  id              String       @id @default(uuid())
  language        String       @default("cpp")
  codeSnippet     String       @db.Text

  // Per-submission notes (scratch pad, observations about this specific code)
  notes           String?      @db.Text

  // Short label/name for this solution, e.g. "Optimized O(log n)", "Recursive"
  // Used as the display title for alternate solutions.
  title           String?

  status          Status       @default(SOLVED)

  // Per-user difficulty rating (0-10). Problem.difficultyValue = AVG of these.
  difficultyRating Float?

  // true  = the primary/canonical solution for this user+problem
  // false = an alternate approach or a later re-submission
  isMainSolution  Boolean      @default(true)

  tags            String[]
  timeComplexity  String?
  spaceComplexity String?

  // Timestamps
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Foreign Keys
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  problemSlug     String
  problem         Problem      @relation(fields: [problemSlug], references: [slug], onDelete: Cascade)

  // Link to the canonical solve record for this user+problem
  solvedProblemId String
  solvedProblem   SolvedProblem @relation(fields: [solvedProblemId], references: [id], onDelete: Cascade)

  // Relationships
  comments        Comment[]
  history         SubmissionHistory[]

  // Indexes
  @@index([userId])
  @@index([problemSlug])
  @@index([solvedProblemId])
  @@index([tags])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([problemSlug, createdAt])
}

// =================================================
// 5. COMMENT TABLE
// =================================================
model Comment {
  id            String       @id @default(uuid())
  content       String       @db.Text

  // Optional code block attached to this comment.
  // Kept separate from prose so the UI can render it in a code viewer.
  codeSnippet   String?      @db.Text
  codeLanguage  String?      // e.g. "cpp", "python" — display hint only, not validated

  createdAt     DateTime     @default(now())

  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  submissionId  String
  submission    Submission   @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
}

// =================================================
// 6. SUBMISSION HISTORY (Audit Log)
// =================================================
model SubmissionHistory {
  id            String       @id @default(uuid())
  oldCode       String       @db.Text
  oldNotes      String?      @db.Text
  changedAt     DateTime     @default(now())

  submissionId  String
  submission    Submission   @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
}